#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

&sk { quick-release; };

/ {
    chosen { zmk,matrix-transform = &imprint_number_row; };

    combos {
        compatible = "zmk,combos";

        enter {
            bindings = <&kp KP_ENTER>;
            key-positions = <33 34>;
        };

        Left_Parenth {
            bindings = <&kp LEFT_PARENTHESIS>;
            key-positions = <16 17>;
            layers = <0>;
            require-prior-idle-ms = <250>;
            timeout-ms = <50>;
        };

        Right_Parenth {
            bindings = <&kp RIGHT_PARENTHESIS>;
            key-positions = <18 19>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        Left_Curly {
            bindings = <&kp LEFT_BRACE>;
            key-positions = <28 29>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        Right_Curly {
            bindings = <&kp RIGHT_BRACE>;
            key-positions = <30 31>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        Left_Bracket {
            bindings = <&kp LEFT_BRACKET>;
            key-positions = <40 41>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        Right_Bracket {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <42 43>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        LEFT_LESS {
            bindings = <&kp LESS_THAN>;
            key-positions = <16 15>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        RIGHT_GREATER {
            bindings = <&kp GREATER_THAN>;
            key-positions = <19 20>;
            layers = <0>;
            timeout-ms = <50>;
            require-prior-idle-ms = <250>;
        };

        COMBO_CARET {
            bindings = <&kp CARET>;
            key-positions = <16 15 19 20>;
            layers = <0>;
        };

        German_Chars {
            bindings = <&sl 10>;
            key-positions = <59 62>;
        };

        Middle_Click_Combo {
            bindings = <&mkp MCLK>;
            key-positions = <53 52>;
        };
    };

    behaviors {
        L_Ctrl: L_Ctrl {
            compatible = "zmk,behavior-hold-tap";
            label = "L_CTRL";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <25>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        L_ALT: L_ALT {
            compatible = "zmk,behavior-hold-tap";
            label = "L_ALT";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <26>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        L_OS: L_OS {
            compatible = "zmk,behavior-hold-tap";
            label = "L_OS";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            hold-trigger-key-positions = <27>;
            require-prior-idle-ms = <250>;
        };

        L_SHIFT: L_SHIFT {
            compatible = "zmk,behavior-hold-tap";
            label = "L_SHIFT";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <280>;
            flavor = "hold-preferred";
            hold-trigger-key-positions = <28>;
            hold-while-undecided;
            require-prior-idle-ms = <250>;
        };

        R_CTRL: R_CTRL {
            compatible = "zmk,behavior-hold-tap";
            label = "R_CTRL";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <34>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        R_ALT: R_ALT {
            compatible = "zmk,behavior-hold-tap";
            label = "R_ALT";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <33>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        R_OS: R_OS {
            compatible = "zmk,behavior-hold-tap";
            label = "R_OS";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <32>;
            tapping-term-ms = <280>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        R_SHIFT: R_SHIFT {
            compatible = "zmk,behavior-hold-tap";
            label = "R_SHIFT";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            hold-trigger-key-positions = <31>;
            tapping-term-ms = <280>;
            flavor = "hold-preferred";
            hold-while-undecided;
            require-prior-idle-ms = <250>;
        };

        C_COPY: C_COPY {
            compatible = "zmk,behavior-hold-tap";
            label = "C_COPY";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            hold-trigger-key-positions = <39>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        V_PASTE: V_PASTE {
            compatible = "zmk,behavior-hold-tap";
            label = "V_PASTE";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            hold-trigger-key-positions = <40>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        SCREAMING_PERIOD: SCREAMING_PERIOD {
            compatible = "zmk,behavior-hold-tap";
            label = "SCREAMING_PERIOD";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <210>;
            flavor = "hold-preferred";
        };

        KEYBOARD_SETTINGS: KEYBOARD_SETTINGS {
            compatible = "zmk,behavior-tap-dance";
            label = "KEYBOARD_SETTINGS";
            #binding-cells = <0>;
            bindings = <&MOD_LAYER>, <&tog 2>;
        };

        QUESTION_MARK: QUESTION_MARK {
            compatible = "zmk,behavior-tap-dance";
            label = "QUESTION_MARK";
            #binding-cells = <0>;
            bindings = <&SCREAMING_PERIOD EXCL PERIOD>, <&kp QUESTION>;
        };

        Z_Undo: Z_Undo {
            compatible = "zmk,behavior-hold-tap";
            label = "Z_UNDO";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            hold-trigger-key-positions = <37>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };

        Quote_tap: Quote_tap {
            compatible = "zmk,behavior-tap-dance";
            label = "QUOTE_TAP";
            #binding-cells = <0>;
            bindings = <&kp SINGLE_QUOTE>, <&kp DOUBLE_QUOTES>;
        };

        Caps_Word_tapdance: Caps_Word_tapdance {
            compatible = "zmk,behavior-hold-tap";
            label = "CAPS_WORD_TAPDANCE";
            bindings = <&mo>, <&caps_word>;

            #binding-cells = <2>;
            tapping-term-ms = <250>;
            hold-trigger-key-positions = <61>;
            flavor = "balanced";
            require-prior-idle-ms = <250>;
        };
    };

    macros {
        ALT_TAB: ALT_TAB {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp TAB &to 7>;
            label = "ALT_TAB";
            wait-ms = <40>;
        };

        ALT_TAB_CLOSE: ALT_TAB_CLOSE {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &to 0>;
            label = "ALT_TAB_CLOSE";
        };

        GG_WP: GG_WP {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RS(ENTER) &kp LS(G) &kp LS(G) &kp SPACE &kp LS(W) &kp LS(P) &kp ENTER>;
            label = "GG_WP";
        };

        EMAIL_ADDRESS: EMAIL_ADDRESS {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp R &kp Y &kp A &kp N &kp DOT &kp M &kp I &kp C &kp H &kp A &kp E &kp L &kp DOT &kp L &kp A &kp T &kp I &kp M &kp E &kp R &kp AT &kp G &kp M &kp A &kp I &kp L &kp DOT &kp C &kp O &kp M>;
            label = "EMAIL_ADDRESS";
        };

        ADDRESS: ADDRESS {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp N3 &kp N0 &kp N7 &kp N6 &kp SPACE &kp LS(S) &kp SPACE &kp LS(N) &kp E &kp X &kp A &kp SPACE &kp LS(P) &kp A &kp S &kp E &kp O>;
            label = "ADDRESS";
        };

        HOME_LAYER: HOME_LAYER {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_COLOR_HSB(0,0,1) &to 0 &rgb_ug RGB_EFR>;
            label = "HOME_LAYER";
        };

        MOD_LAYER: MOD_LAYER {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&mo 1>,
                <&macro_tap>,
                <&rgb_ug RGB_COLOR_HSB(128,1,1)>,
                <&macro_pause_for_release>,
                <&macro_release>,
                <&mo 1>,
                <&macro_tap>,
                <&rgb_ug RGB_COLOR_HSB(0,0,1)>;

            label = "MOD_LAYER";
        };

        GAMING_LAYER: GAMING_LAYER {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_COLOR_HSB(180,94,1) &rgb_ug RGB_EFF &tog 4>;
            label = "GAMING_LAYER";
        };

        GAMING_LAYER_NONSHIFT: GAMING_LAYER_NONSHIFT {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_EFF &tog 5>;
            label = "GAMING_LAYER_NONSHIFT";
        };

        HOME_FROM_SHIFTED: HOME_FROM_SHIFTED {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&rgb_ug RGB_EFR &HOME_LAYER>;
            label = "HOME_FROM_SHIFTED";
        };

        o_umlaut_lower: o_ummlat_lower {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_4 &kp KP_NUMBER_6 &kt LEFT_ALT>;
            label = "O_UMMLAT_lower";
        };

        O_umlaut: O_umlaut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_1 &kp KP_NUMBER_4 &kt LEFT_ALT>;
            label = "O_UMLAUT";
        };

        a_umlaut_lower: a_umlaut_lower {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_2 &kp KP_NUMBER_8 &kt LEFT_ALT>;
            label = "A_UMLAUT_LOWER";
        };

        A_umlaut: A_umlaut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_1 &kp KP_NUMBER_9 &kp KP_NUMBER_6 &kt LEFT_ALT>;
            label = "A_UMLAUT";
        };

        u_umlaut_lower: u_umlaut_lower {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_5 &kp KP_NUMBER_2 &kt LEFT_ALT>;
            label = "U_UMLAUT_LOWER";
        };

        U_umlaut: U_umlaut {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_2 &kp KP_NUMBER_0 &kt LEFT_ALT>;
            label = "U_UMLAUT";
        };

        s_sharp_lower: s_sharp_lower {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_2 &kp KP_NUMBER_2 &kp KP_NUMBER_3 &kt LEFT_ALT>;
            label = "S_SHARP_LOWER";
        };

        S_sharp: S_sharp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_7 &kp KP_NUMBER_8 &kp KP_NUMBER_3 &kp KP_NUMBER_8 &kt LEFT_ALT>;
            label = "S_SHARP";
        };

        euro: euro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kt LEFT_ALT &kp KP_NUMBER_0 &kp KP_NUMBER_1 &kp KP_NUMBER_2 &kp KP_NUMBER_8 &kt LEFT_ALT>;
            label = "EURO";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp EQUAL  &kp N1           &kp N2             &kp N3            &kp N4                 &kp N5                      &kp N6                   &kp N7                  &kp N8             &kp N9              &kp N0                   &kp MINUS
&kp TAB    &kp Q            &kp W              &kp E             &kp R                  &kp T                       &Z_Undo LC(Y) Y          &kp U                   &kp I              &kp O               &Z_Undo PERCENT P        &kp BSLH
&kp ESC    &L_Ctrl LCTRL A  &L_ALT LEFT_ALT S  &L_OS LEFT_WIN D  &L_SHIFT LEFT_SHIFT F  &kp G                       &kp H                    &R_SHIFT RIGHT_SHIFT J  &R_OS RIGHT_WIN K  &R_ALT RIGHT_ALT L  &R_CTRL RCTRL SEMICOLON  &Quote_tap
&kp COLON  &Z_Undo LC(Z) Z  &Z_Undo LC(X) X    &C_COPY LC(C) C   &V_PASTE LC(V) V       &kp B                       &kp N                    &kp M                   &kp COMMA          &QUESTION_MARK      &kp FSLH                 &kp UNDERSCORE
                            &kp LEFT_ARROW     &kp RIGHT_ARROW                                                                                                       &kp DOWN_ARROW     &kp UP_ARROW
                                                                 &mkp LCLK              &mkp RCLK       &ALT_TAB    &kp LC(LG(LEFT_ARROW))   &kp LG(LC(D))           &kp LC(LG(RIGHT))
                                                                 &kp BACKSPACE          &sk LEFT_SHIFT  &mo 1       &Caps_Word_tapdance 1 0  &kp SPACE               &kp LG(LS(S))
            >;
        };

        Numpad_Nav_Layer {
            bindings = <
&kp F12  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5                   &kp F6          &kp F7          &kp F8        &kp F9     &kp F10  &kp F11
&to 0    &trans  &kp N7  &kp N8  &kp N9  &trans                   &trans          &kp HOME        &kp UP        &kp END    &trans   &trans
&trans   &trans  &kp N4  &kp N5  &kp N6  &kp LA(LS(R))            &kp LEFT_ARROW  &kp DOWN        &kp UP_ARROW  &kp RIGHT  &trans   &trans
&trans   &trans  &kp N1  &kp N2  &kp N3  &kp LA(LS(S))            &tog 2          &tog 4          &tog 5        &tog 6     &tog 8   &trans
                 &trans  &kp N0                                                                   &trans        &trans
                                 &trans  &trans         &trans    &trans          &kp LG(LC(F4))  &trans
                                 &trans  &trans         &to 0     &trans          &trans          &trans
            >;
        };

        Keyboard_Control_Layer {
            bindings = <
&bt BT_CLR   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4              &trans          &rgb_ug RGB_TOG  &rgb_ug RGB_EFF  &trans           &trans           &trans
&to 0        &sys_reset    &trans        &trans        &trans        &studio_unlock            &studio_unlock  &rgb_ug RGB_HUI  &rgb_ug RGB_SAI  &rgb_ug RGB_BRI  &rgb_ug RGB_SPI  &sys_reset
&bootloader  &trans        &trans        &trans        &trans        &trans                    &trans          &rgb_ug RGB_HUD  &rgb_ug RGB_SAD  &rgb_ug RGB_BRD  &rgb_ug RGB_SPD  &bootloader
&to 0        &trans        &trans        &trans        &trans        &trans                    &trans          &trans           &trans           &trans           &trans           &to 0
                           &trans        &trans                                                                                 &trans           &trans
                                                       &trans        &trans          &trans    &trans          &trans           &trans
                                                       &trans        &trans          &trans    &trans          &trans           &trans
            >;
        };

        Auto_Mouse_Layer {
            bindings = <
&trans  &trans  &trans     &trans     &trans     &trans            &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans     &trans     &trans     &trans            &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &mkp RCLK  &mkp MCLK  &mkp LCLK  &trans            &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans     &trans     &trans     &trans            &trans  &trans  &trans  &trans  &trans  &trans
                &trans     &trans                                                  &trans  &trans
                                      &trans     &trans  &trans    &trans  &trans  &trans
                                      &trans     &trans  &trans    &trans  &trans  &trans
            >;
        };

        Gaming_Shifted {
            bindings = <
&trans  &kp GRAVE  &kp N1    &kp N2     &kp N3         &kp N4                             &kp N5  &kp N6  &kp N7    &kp N8     &kp N9   &kp N0
&trans  &kp TAB    &kp Q     &kp W      &kp E          &kp R                              &kp T   &kp Y   &kp U     &kp I      &kp O    &kp P
&trans  &kp CAPS   &kp A     &kp S      &kp D          &kp F                              &kp G   &kp H   &kp J     &kp K      &kp L    &kp SEMI
&trans  &kp LSHFT  &kp Z     &kp X      &kp C          &kp V                              &kp B   &kp N   &kp M     &kp COMMA  &kp DOT  &to 0
                   &kp LEFT  &kp RIGHT                                                                    &kp DOWN  &kp UP
                                        &kp LALT       &kp LSHFT         &kp TILDE        &trans  &trans  &trans
                                        &kp BACKSPACE  &kp LEFT_CONTROL  &kp BACKSPACE    &trans  &trans  &trans
            >;
        };

        Gaming_Naked {
            bindings = <
&kp ESC    &kp N1  &kp N2    &kp N3     &kp N4        &kp N5              &kp N6  &kp N7  &kp N8     &kp N9          &kp N0    &trans
&kp TAB    &kp Q   &kp W     &kp E      &kp R         &kp T               &kp Y   &kp U   &kp I      &kp O           &kp P     &GG_WP
&kp CAPS   &kp A   &kp S     &kp D      &kp F         &kp G               &kp H   &kp J   &kp K      &kp L           &kp SEMI  &kp APOS
&kp LSHFT  &kp Z   &kp X     &kp C      &kp V         &kp B               &kp N   &kp M   &kp COMMA  &QUESTION_MARK  &kp FSLH  &to 0
                   &kp LEFT  &kp RIGHT                                                    &kp DOWN   &kp UP
                                        &kp LEFT_ALT  &trans     &kp H    &trans  &trans  &trans
                                        &trans        &kp LCTRL  &kp Y    &trans  &trans  &trans
            >;
        };

        zeri {
            bindings = <
&kp ESC    &kp N1  &kp N2    &kp N3     &kp N4    &kp N5              &kp N6  &kp N7  &kp N8     &kp N9   &kp N0    &kp MINUS
&kp TAB    &kp R   &kp W     &kp E      &kp Q     &kp T               &kp Y   &kp U   &kp I      &kp O    &kp P     &kp LBKT
&kp CAPS   &kp A   &kp S     &kp D      &kp F     &kp G               &kp H   &kp J   &kp K      &kp L    &kp SEMI  &kp APOS
&kp LSHFT  &kp Z   &kp X     &kp C      &kp V     &kp B               &kp N   &kp M   &kp COMMA  &kp DOT  &kp FSLH  &to 0
                   &kp LEFT  &kp RIGHT                                                &kp DOWN   &kp UP
                                        &kp LALT  &trans     &kp H    &trans  &trans  &trans
                                        &trans    &kp LCTRL  &kp Y    &trans  &trans  &trans
            >;
        };

        ALTTAB {
            bindings = <
&none  &none  &none  &none  &none  &none                    &none   &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none                    &none   &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none                    &none   &none  &none  &none  &none  &none
&none  &none  &none  &none  &none  &none                    &none   &none  &none  &none  &none  &none
              &none  &none                                                 &none  &none
                            &none  &none  &kp TAB           &none   &none  &none
                            &none  &none  &ALT_TAB_CLOSE    &trans  &none  &none
            >;
        };

        Runescape {
            bindings = <
&kp GRAVE  &kp N1  &kp N2  &kp N3  &kp N4    &kp N5               &kp N6  &kp N7     &kp N8     &kp N9   &kp N0    &kp MINUS
&kp TAB    &kp Q   &kp W   &kp E   &kp R     &kp T                &kp Y   &kp U      &kp I      &kp O    &kp P     &kp LBKT
&kp PIPE   &kp A   &kp S   &kp D   &kp F     &kp G                &kp H   &kp J      &kp K      &kp L    &kp SEMI  &kp APOS
&kp BSLH   &kp Z   &kp X   &kp C   &kp V     &kp B                &kp N   &kp M      &kp COMMA  &kp DOT  &kp FSLH  &to 0
                   &trans  &trans                                                    &trans     &trans
                                   &trans    &trans  &kp LC(I)    &trans  &trans     &trans
                                   &kp BSPC  &mo 9   &kp LC(U)    &trans  &kp SPACE  &trans
            >;
        };

        Runescape_shifted {
            bindings = <
&kp ESC  &kp N6  &kp N7  &kp N8     &kp N9   &kp N0              &trans  &trans  &trans  &trans  &trans  &trans
&trans   &kp Y   &kp U   &kp I      &kp O    &kp P               &trans  &trans  &trans  &trans  &trans  &trans
&trans   &kp H   &kp J   &kp K      &kp L    &kp SEMI            &trans  &trans  &trans  &trans  &trans  &trans
&trans   &kp N   &kp M   &kp COMMA  &kp DOT  &kp FSLH            &trans  &trans  &trans  &trans  &trans  &trans
                 &trans  &trans                                                  &trans  &trans
                                    &trans   &trans    &trans    &trans  &trans  &trans
                                    &trans   &trans    &trans    &trans  &trans  &trans
            >;
        };

        layer_10 {
            bindings = <
&trans  &trans           &trans          &trans  &trans  &trans            &trans  &trans           &trans  &trans           &trans  &trans
&trans  &trans           &trans          &trans  &trans  &trans            &trans  &u_umlaut_lower  &trans  &o_umlaut_lower  &trans  &trans
&trans  &a_umlaut_lower  &s_sharp_lower  &trans  &trans  &trans            &trans  &trans           &trans  &trans           &trans  &trans
&trans  &trans           &trans          &trans  &trans  &trans            &trans  &trans           &trans  &trans           &trans  &trans
                         &trans          &trans                                                     &trans  &trans
                                                 &trans  &trans  &trans    &trans  &trans           &trans
                                                 &trans  &sl 11  &trans    &trans  &trans           &trans
            >;
        };

        layer_11 {
            bindings = <
&trans  &trans     &trans    &trans  &euro   &trans            &trans  &trans     &trans  &trans     &trans  &trans
&trans  &trans     &trans    &trans  &trans  &trans            &trans  &U_umlaut  &trans  &O_umlaut  &trans  &trans
&trans  &A_umlaut  &S_sharp  &trans  &trans  &trans            &trans  &trans     &trans  &trans     &trans  &trans
&trans  &trans     &trans    &trans  &trans  &trans            &trans  &trans     &trans  &trans     &trans  &trans
                   &trans    &trans                                               &trans  &trans
                                     &trans  &trans  &trans    &trans  &trans     &trans
                                     &trans  &trans  &trans    &trans  &trans     &trans
            >;
        };
    };
};

// left hand trackball configuration (unused)
// &trackball_central_listener {
// };
// right hand trackball configuration

&trackball_peripheral_listener {
    input-processors = <&zip_xy_scaler 2 3>;

    scroller {
        layers = <1>;
        input-processors = <&zip_xy_scaler 1 60>, <&zip_xy_to_scroll_mapper>;
    };
};
